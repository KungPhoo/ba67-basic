1 ER=0
10 PRINT "COMMODORE 64 BASIC V2 TEST PROGRAM"
20 PRINT "  TESTING NUMERIC OPERATIONS..."
30 IF (2+2)<>(4) THEN          ER=1:PRINT "ERROR: ADDITION"
40 IF (10-3)<>(7) THEN         ER=1:PRINT "ERROR: SUBTRACTION"
50 IF (5*5)<>(25) THEN         ER=1:PRINT "ERROR: MULTIPLICATION"
60 IF (20/4)<>(5) THEN         ER=1:PRINT "ERROR: DIVISION"
70 IF ABS(100-10^2)>0.001 THEN ER=1:PRINT "ERROR: EXPONENTIATION"
71 IF INT(4.9)<>4 THEN         ER=1:PRINT "ERROR: INT"
72 IF VAL(STR$(4.9))<>4.9 THEN ER=1:PRINT "ERROR: VAL, STR$"
74 IF -3+4*(-2)-(-(-5))/(3+-1)<>-13.5 THEN ER=1: PRINT "ERROR: COMPLEX MATH 1"
75 PRINT "  PASS COMPLEX MATH 2"
80 PRINT "  NUMERIC OPERATIONS PASSED. ER";ER
90 PRINT "  TESTING STRING OPERATIONS..."
100 IF ("HELLO"+" WORLD")<>"HELLO WORLD" THEN ER=1:PRINT "ERROR: STRING CONCATENATION"
110 A$="C64"
120 IF (LEN(A$))<>(3) THEN       ER=1:PRINT "ERROR: LEN()"
130 IF (LEFT$(A$,2))<>"C6" THEN  ER=1:PRINT "ERROR: LEFT$()"
140 IF (RIGHT$(A$,2))<>"64" THEN ER=1:PRINT "ERROR: RIGHT$()"
150 IF (MID$(A$,2,1))<>"6" THEN  ER=1:PRINT "ERROR: MID$()"
160 PRINT "  STRING OPERATIONS PASSED. ER";ER
170 PRINT "  TESTING VARIABLES AND ASSIGNMENTS..."
180 A=10: B=5: C=(A+B)
190 IF (C)<>(15) THEN ER=1:PRINT "ERROR: VARIABLE ASSIGNMENT"
200 PRINT "  VARIABLE ASSIGNMENTS PASSED. ER";ER
201 PRINT "  TESTING DIM..."
202 DIM ARR(4,5)
203 FOR X = 1 TO 4: FOR Y = 1 TO 5
204 ARR(X,Y) = X+Y
205 NEXT Y:NEXT X
206 IF ARR(2,3) <> 2+3 THEN ER=1:PRINT "ERROR: DIM"
208 PRINT "  DIM PASSED, IF 5 = ";INT(ARR(2,3));". ER";ER
210 PRINT "  TESTING CONDITIONALS..."
220 IF (1=0) THEN   ER=1:PRINT "ERROR: EQUALITY TEST"
230 IF (5<3) THEN   ER=1:PRINT "ERROR: LESS THAN TEST"
240 IF (10>20) THEN ER=1:PRINT "ERROR: GREATER THAN TEST"
250 PRINT "  CONDITIONALS PASSED. ER";ER
260 PRINT "  TESTING LOOPS..."
270 S=0
280 FOR I=1 TO 10: S=S+I: NEXT I
290 IF (S)<>(55) THEN ER=1:PRINT "ERROR: FOR-NEXT LOOP"
