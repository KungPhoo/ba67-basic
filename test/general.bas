310 PRINT "  TESTING NESTED LOOPS..."
315 S=0
316 FOR I=1 TO 5
317 FOR J=1 TO 5
318 S=S+1
319 NEXT J
320 NEXT I
321 IF (S)<>(25) THEN ER=1:PRINT "ERROR: NESTED LOOP"
322 PRINT "  NESTED LOOPS PASSED. ER";ER
330 PRINT "  TESTING GOSUB AND RETURN..."
340 GOSUB 500
350 IF (R)<>(42) THEN ER=1:PRINT "ERROR: GOSUB/RETURN"
360 PRINT "  GOSUB AND RETURN PASSED. ER";ER
370 PRINT "  TESTING PRINT SPACING..."
380 PRINT "  ..."; ",,";"...X--- SEMICOLON"
390 PRINT "  ...","X--- COMMA"
400 PRINT SPC(5); ",,,,,X--- SPACED"
410 PRINT TAB(10); "X--- TABBED"
420 PRINT "      ALL X MUST ALIGN"
430 PRINT "  ALL TESTS COMPLETED! ER";ER
440 QUIT ER:REM FOR TESTING
450 END
